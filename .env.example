# ============================================================
# RDP S.A. — PARQUEOS ESQUIPULAS — Variables de Entorno
# Copiar como .env y completar con valores reales.
# NUNCA subir .env al repositorio (está en .gitignore).
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT (autenticación legacy/Express) ───────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Email (Resend.com) ────────────────────────────────────────
RESEND_API_KEY=re_demo_key
EMAIL_FROM=noreply@rdpparqueos.com

# ── Supabase ──────────────────────────────────────────────────
# Obtener en: https://app.supabase.com → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Service role key (solo backend, NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Firebase (notificaciones push) ───────────────────────────
# Obtener en: https://console.firebase.google.com → Project Settings
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
# VAPID key para Web Push → Firebase Console → Cloud Messaging → Web Push certificates
FIREBASE_VAPID_KEY=

# ── Vercel (deployment) ───────────────────────────────────────
# Estos son inyectados automáticamente por Vercel; incluir aquí solo para dev local
VERCEL_ENV=development
VERCEL_URL=localhost:3000

# ── Base de datos MySQL legacy (solo si se usa el modo mock+MySQL) ─────
# Dejar vacío para usar datos mock en desarrollo
DB_HOST=
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=parqueo
DB_POOL_SIZE=10
