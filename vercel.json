{
  "version": 2,
  "functions": {
    "api/index.js": { "runtime": "@vercel/node" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/",         "destination": "/public/index.html" },
    { "source": "/(.*)",     "destination": "/public/$1" }
  ]
}
